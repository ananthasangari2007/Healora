PORT=3000

# SMTP server settings
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your-16-character-app-password
#
# Brevo example:
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login-email
SMTP_PASS=your-smtp-key-or-password

# Contact flow emails
# CONTACT_FROM_EMAIL is the sender address shown on outgoing mail.
# For Gmail SMTP, this should usually be the same as SMTP_USER.
# For Brevo or another provider, this must be a sender address verified there.
CONTACT_FROM_EMAIL=your-verified-sender-email
CONTACT_TO_EMAIL=your-receiving-email@gmail.com
